# PostgreSQL
DATABASE_URL=postgresql://aicrew:aicrew_password@postgres:5432/aicrew

# Backend
PORT=3000

# Docker
OPENCLAW_IMAGE=alpine/openclaw:latest
DOCKER_NETWORK=ai_crew_network

# Slack OAuth
SLACK_CONFIG_TOKEN=           # Slack Configuration Token (xoxe.xoxp-...) from api.slack.com
SLACK_CONFIG_REFRESH_TOKEN=   # Slack Configuration Refresh Token (xoxe-1-...) for auto-renewal
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/api/slack-oauth/callback
APP_BASE_URL=http://localhost:5173
